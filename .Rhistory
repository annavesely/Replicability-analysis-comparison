getFixedDelta <- function(m=1000, s=10, deltaPar=1.5){
m0 <- floor(m/2)
m0 <- 1
m1 <- m - m0
sinit <- s
delta <- c(rep(0,m0), sort(rep(sinit:s, length.out=m1)))
return(delta)
}
